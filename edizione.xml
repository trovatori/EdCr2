<front>

  <div type="introduction">
    <head>Introduzione</head>
    <p>
      Questo lavoro presenta un’edizione critica del testo,
      basata sui testimoni A e B.
    </p>
  </div>

  <div type="preface">
    <head>Prefazione</head>
    <p>
      L’edizione è stata realizzata secondo criteri conservativi.
    </p>
  </div>

  <div type="introduction">
    <head>Prefazione</head>
    <p>
      L’edizione è stata realizzata secondo criteri conservativi.
    </p>
  </div>

  <div type="editorialNote">
    <head>Nota al testo</head>
    <p>
      Il testo base è il testimone A.
    </p>
  </div>

  <div type="criteria">
    <head>Criteri editoriali</head>
    <p>
      Le varianti sono segnalate in apparato con note numerate.
    </p>
  </div>

</front>


    <body>
      <div type="edition">
        <lg>
          <l n="1">
            Nel mezzo del cammin di nostra 
            <app xml:id="v1">
              <lem wit="#A">vita</lem>
              <rdg wit="#B">strada</rdg>
              <rdg wit="#C" type="orthographic">uida</rdg>
            </app>,
          </l>
          <l n="2">
            mi ritrovai per una 
            <app xml:id="v2">
              <lem wit="#A">selva</lem>
              <rdg wit="#B">foresta</rdg>
            </app> oscura.
          </l>
        </lg>
        <lg>
          <l n="3">
            Nel mezzo del cammin di nostra 
            <app xml:id="v3">
              <lem wit="#A">vita</lem>
              <rdg wit="#B">strada</rdg>
            </app>,
          </l>
          <l n="4">
            mi ritrovai per una 
            <app xml:id="v4">
              <lem wit="#A">selva</lem>
              <rdg wit="#B">foresta</rdg>
            </app> oscura.
          </l>
        </lg>

        <lg>
          <l n="5">
            Nel mezzo del cammin di nostra 
            <app xml:id="v5">
              <lem wit="#A">vita</lem>
              <rdg wit="#B">strada</rdg>
            </app>,
          </l>
          <l n="6">
            mi ritrovai per una 
            <app xml:id="v6">
              <lem wit="#A">selva</lem>
              <rdg wit="#B #C">foresta</rdg>
            </app> oscura.
          </l>
        </lg>
        <lg>
          <l n="7">
            Nel mezzo del cammin di nostra 
            <app xml:id="v7">
              <lem wit="#A">vita</lem>
              <rdg wit="#B">strada</rdg>
            </app>,
          </l>
          <l n="8">
            mi ritrovai per una 
            <app xml:id="v8">
              <lem type="conjecture">selva</lem>
              <rdg wit="#A #C"></rdg>
              <rdg wit="#B">foresta</rdg>
            </app> oscura.
          </l>
        </lg>
        <lg>
          <l n="9">
            Nel mezzo del cammin di nostra 
            <app xml:id="v9">
              <lem wit="#A">vita</lem>
              <rdg wit="#B">strada</rdg>
              <rdg wit="#C">strida</rdg>
            </app>,
          </l>
          <l n="10">
            mi ritrovai per una 
            <app xml:id="v10">
              <lem wit="#A">selva</lem>
              <rdg wit="#B">foresta</rdg>
            </app> oscura.
          </l>
        </lg>
   <lg>
          <l n="11">
            Nel mezzo del cammin di nostra vita
          </l>
          <l n="12">  mi ritrovai per una 
              <app xml:id="v12">
                <lem wit="#A">selva</lem>
                <rdg wit="#B">foresta</rdg>
              </app> 
  <seg xml:id="n3">oscura</seg>. </l>
        </lg>
        <note target="#v1">Nota al verso 1: "vita" è lezione vulgata.</note>
        <note target="#v6">Nota al verso 2: "selva" come allegoria del peccato.</note>
        <note target="#n3">Nota di commento a "oscura".</note>
      </div>
